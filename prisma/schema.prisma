generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  resumes       Resume[]
  jobDescriptions JobDescription[]
  interviewPreps  InterviewPrep[]
  aiSuggestions   AiSuggestion[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  name        String
  email       String
  phone       String
  location    String
  targetRole  String
  summary     String   @db.Text
  skillsJson  Json
  educationJson Json
  projectsJson  Json
  experienceJson Json
  linksJson      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  id            String   @id @default(cuid())
  userId        String
  title         String
  baseProfileId String?
  contentJson   Json
  versions      ResumeVersion[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ResumeVersion {
  id            String   @id
  resumeId      String
  userId        String
  name          String
  targetCompany String
  targetRole    String
  jdId          String?
  contentJson   Json
  matchScoreJson Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model JobDescription {
  id             String   @id
  userId         String
  company        String
  role           String
  rawText        String   @db.Text
  seniority      String?
  extractedKeywordsJson Json
  requiredSkillsJson    Json
  niceToHaveJson        Json
  softSkillsJson        Json
  responsibilitiesJson  Json
  emphasisJson          Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewPreps InterviewPrep[]
}

model InterviewPrep {
  id           String   @id @default(cuid())
  userId       String
  jdId         String
  questionsJson Json
  answersJson   Json
  feedbackJson  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobDescription JobDescription @relation(fields: [jdId], references: [id], onDelete: Cascade)
}

model AiSuggestion {
  id            String   @id @default(cuid())
  userId        String
  resumeId      String?
  jdId          String?
  type          String
  originalText  String   @db.Text
  suggestedText String   @db.Text
  reason        String   @db.Text
  model         String?
  metadataJson  Json?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
